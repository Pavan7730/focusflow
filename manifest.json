{
  "manifest_version": 3,
  "name": "FocusFlow – Productivity Tracker",
  "description": "Helps users understand how they spend time on websites to improve focus and productivity.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage",
    "idle"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

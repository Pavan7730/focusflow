{
  "manifest_version": 3,
  "name": "FocusFlow – Productivity Tracker",
  "description": "Helps users understand and improve focus by tracking time spent on websites.",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage", "idle"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
